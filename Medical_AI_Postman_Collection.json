            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"محمد علي\",\n  \"phone\": \"01012345678\",\n  \"email\": \"patient@example.com\",\n  \"national_id\": \"30001011234567\",\n  \"date_of_birth\": \"2000-01-01\",\n  \"gender\": \"male\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/patients/",
              "host": ["{{base_url}}"],
              "path": ["patients", ""]
            }
          }
        },
        {
          "name": "Search Patient (by name or phone)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/patients/?q=محمد",
              "host": ["{{base_url}}"],
              "path": ["patients", ""],
              "query": [
                {
                  "key": "q",
                  "value": "محمد",
                  "description": "ابحث بالاسم أو رقم التليفون"

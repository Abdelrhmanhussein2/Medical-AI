						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"مراجعة الرنين المغناطيسي للمريض: أحمد محمد\",\n  \"dept\": \"Neurology\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/chat/threads",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"chat",
								"threads"
							]
						}
					},
					"response": []
				},

						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sender_type\": \"user\",\n  \"content\": \"ما هي موانع استعمال دواء الوارفارين مع المريض؟\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/chat/threads/{{active_thread_id}}/messages",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"chat",
								"threads",
								"{{active_thread_id}}",
								"messages"
							]
						}
					},
					"response": []
				},
				{
					"name": "جلب رسائل محادثة (Get Thread Messages)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/chat/threads/{{active_thread_id}}/messages?limit=50",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"chat",
								"threads",
								"{{active_thread_id}}",
								"messages"
							],
							"query": [
								{
									"key": "limit",
									"value": "50"
								},
								{
									"key": "before",
									"value": "",
									"disabled": true
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "حذف رسالة معينة (Delete Message)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/chat/threads/{{active_thread_id}}/messages/{{message_id}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"chat",
								"threads",
								"{{active_thread_id}}",
								"messages",
								"{{message_id}}"
							]
						}
					},
					"response": []
				}
			]
		}

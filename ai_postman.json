								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"مراجعة الرنين المغناطيسي للمريض: أحمد محمد (محدث)\",\n  \"is_pinned\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/chat/threads/{{active_thread_id}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"chat",
								"threads",
								"{{active_thread_id}}"
							]
						}
					},
					"response": []

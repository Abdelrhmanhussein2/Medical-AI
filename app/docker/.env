# PostgreSQL Database Settings
DB_USER=medical_user
DB_PASSWORD=medical_pass123
DB_NAME=medical_ai
DB_PORT=5432

# Full DATABASE_URL for asyncpg (used in app/core/config.py)
DATABASE_URL=postgresql://medical_user:medical_pass123@localhost:5432/medical_ai

# App Secret
SECRET_KEY=your-super-secret-key-change-in-production

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (JWT)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days
